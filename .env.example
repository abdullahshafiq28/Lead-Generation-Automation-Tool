# =========================================================================
#  Optional configuration. Copy this file to ".env" and fill in values.
#  If a value is absent, the workflow gracefully SKIPS that feature and
#  produces the same core CSV (deduped, scored leads) — nothing breaks.
# =========================================================================

# --- AI / Gemini (outreach hooks + embedding-based scoring) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-lite-latest
#   (embedding model is fixed to gemini-embedding-001 in the workflow)

# --- Email push (optional) ---
#   Set SEND_EMAIL=true AND create an "SMTP" credential in the n8n UI.
SEND_EMAIL=false
# SMTP_FROM=you@gmail.com          # the sending Gmail (should match the SMTP login)
# EMAIL_TO=recipient@gmail.com     # who receives the CSV (defaults to husnainkhalid626@gmail.com)

# --- Output directory (Docker only) ---
#   Local npx runs: leave unset (writes to ./output).
#   Docker: set OUTPUT_DIR=/data/output (the mounted volume).
# OUTPUT_DIR=/data/output
